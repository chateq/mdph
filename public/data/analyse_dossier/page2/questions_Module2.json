          "id": "analyse_autonomie_globale",
          "title": "Globalement, votre état de santé limite votre autonomie :",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "faiblement", "label": "Faiblement" },
