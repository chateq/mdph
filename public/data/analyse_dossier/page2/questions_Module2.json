{
  "sections": [
    {
      "id": "comprendre_decision",
      "title": "",
      "questions": [
        {
          "id": "analyse_aide_refusee",
          "title": "Quelle aide MDPH a été refusée ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "aah", "label": "Allocation Adulte Handicapé (AAH)" },
            { "value": "pch", "label": "Prestation de Compensation du Handicap (PCH)" },
            { "value": "rqth", "label": "Reconnaissance de la Qualité de Travailleur Handicapé (RQTH)" },
            { "value": "cmi", "label": "Carte Mobilité Inclusion (CMI)" },
            { "value": "orientation_pro", "label": "Orientation professionnelle" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez l’aide concernée" }
          ]
        },
        {
          "id": "analyse_type_demande",
          "title": "Cette demande était:",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "premiere", "label": "Une première demande" },
            { "value": "renouvellement", "label": "Un renouvellement" },
            { "value": "reevaluation", "label": "Une réévaluation de votre situation" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez votre situation" }
          ]
        },
        {
          "id": "analyse_date_decision",
          "title": "Quelle est la date indiquée sur la décision MDPH ?",
          "description": "",
          "type": "date",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'"
        },
        {
          "id": "analyse_decision_correspond_a",
          "title": "La décision correspond à :",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "refus_total", "label": "Un refus total" },
            { "value": "refus_partiel", "label": "Un refus partiel", "followUp": {
              "id": "analyse_ce_qui_accorde",
              "title": "Qu'est-ce qui a été accordé par la MDPH ?",
              "type": "text",
              "placeholder": "Précisez ce qui a été accordé par la MDPH...",
              "obligatoire": true
            }},
            { "value": "incomprehensible", "label": "Je ne comprends pas la décision" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez votre suivi médical" }
          ]
        },
        {
          "id": "analyse_motif_courrier",
          "title": "Quel motif est indiqué dans le courrier de décision ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "taux_insuffisant", "label": "Taux d’incapacité jugé insuffisant" },
            { "value": "capacite_travail", "label": "Capacité de travail jugée possible" },
            { "value": "dossier_insuffisant", "label": "Dossier médical jugé insuffisant" },
            { "value": "non_stabilisee", "label": "Situation jugée non stabilisée" },
            { "value": "aucun_motif", "label": "Aucun motif clairement expliqué" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez le motif indiqué :" }
          ]
        },
        {
          "id": "analyse_phrase_courrier",
          "title": "Copiez la phrase du courrier qui explique le refus",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : 'Après examen de votre demande d'Allocation Adulte Handicapé, la Commission départementale a décidé de ne pas vous attribuer cette prestation car votre taux d'incapacité est estimé à 78%'...",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'"
        }
      ]
    },
    {
      "id": "situation_medicale",
      "title": "",
      "questions": [
        {
          "id": "analyse_pathologie",
          "title": "Quelle est votre maladie ou votre handicap principal ?",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : Sclérose en plaques diagnostiquée en 2020. Fatigue chronique sévère, troubles de la marche avec risque de chutes, et difficultés de concentration...",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'"
        },
        {
          "id": "analyse_duree_difficultes",
          "title": "Depuis combien de temps avez-vous ces difficultés ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "moins_6_mois", "label": "Moins de 6 mois" },
            { "value": "6_mois_2_ans", "label": "Entre 6 mois et 2 ans" },
            { "value": "plus_2_ans", "label": "Plus de 2 ans" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        },
        {
          "id": "analyse_suivi_specialiste",
          "title": "Êtes-vous suivi par un médecin spécialiste ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "oui", "label": "Oui" },
            { "value": "non", "label": "Non" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez votre suivi médical" }
          ]
        },
        {
          "id": "analyse_aggravation_recent",
          "title": "Votre état de santé s'est-il aggravé récemment ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "recours_choix_action === 'analyse'",
          "options": [
            { "value": "non", "label": "Non" },
            { "value": "oui", "label": "Oui", "followUp": {
              "id": "analyse_aggravation_depuis_quand",
              "title": "Depuis quand votre état s'est-il aggravé ?",
              "type": "radio",
              "obligatoire": true,
              "options": [
                { "value": "moins_6_mois", "label": "Moins de 6 mois" },
                { "value": "6_12_mois", "label": "Entre 6 et 12 mois" },
                { "value": "plus_1_an", "label": "Plus d'un an" },
                { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
              ]
            }},
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        }
      ]
    },
    {
