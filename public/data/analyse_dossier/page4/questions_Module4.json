{
  "sections": [
    {
      "id": "autorite_juridiction",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_mdph_departement",
          "title": "Quelle MDPH a pris la décision contestée ?",
          "description": "",
          "type": "text",
          "placeholder": "Exemple : MDPH d'Ille-et-Vilaine",
          "obligatoire": true
        },
        {
          "id": "contentieux_departement_tribunal",
          "title": "Dans quel département se situe la MDPH concernée ?",
          "description": "",
          "type": "text",
          "placeholder": "Exemple : Ille-et-Vilaine",
          "obligatoire": true
        }
      ]
    },
    {
      "id": "identification_decision",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_aide_concernee",
          "title": "Quelle aide est concernée par la décision contestée ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "aah", "label": "Allocation adulte handicapé (AAH)" },
            { "value": "pch", "label": "Prestation de compensation du handicap (PCH)" },
            { "value": "rqth", "label": "Reconnaissance de la qualité de travailleur handicapé (RQTH)" },
            { "value": "cmi", "label": "Carte mobilité inclusion (CMI)" },
            { "value": "orientation_pro", "label": "Orientation professionnelle" },
            { "value": "autre", "label": "Autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        },
        {
          "id": "contentieux_type_demande",
          "title": "Cette demande était :",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "premiere", "label": "première demande" },
            { "value": "renouvellement", "label": "renouvellement" },
            { "value": "reevaluation", "label": "réévaluation" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        },
        {
          "id": "contentieux_date_decision",
          "title": "Date de la décision de la MDPH",
          "description": "",
          "type": "date",
          "obligatoire": true
        },
        {
          "id": "contentieux_date_reception_decision",
          "title": "Date à laquelle vous avez reçu cette décision",
          "description": "",
          "type": "date",
          "obligatoire": true
        },
        {
          "id": "contentieux_numero_dossier",
          "title": "Numéro de dossier ou référence indiquée sur la notification",
          "description": "",
          "type": "text",
          "placeholder": "Exemple : 2024-MDPH-123456",
          "obligatoire": true
        },
        {
          "id": "contentieux_motif_courrier",
          "title": "Quel motif est indiqué dans le courrier de décision ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "taux_insuffisant", "label": "taux d’incapacité jugé insuffisant" },
            { "value": "capacite_travail", "label": "capacité de travail jugée possible" },
            { "value": "dossier_insuffisant", "label": "dossier médical insuffisant" },
            { "value": "non_stabilisee", "label": "situation jugée non stabilisée" },
            { "value": "aucun_motif", "label": "aucun motif clairement indiqué" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        },
        {
          "id": "contentieux_phrase_courrier",
          "title": "Copiez la phrase du courrier expliquant le refus",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : 'Après examen de votre dossier, la Commission des Droits et de l'Autonomie des Personnes Handicapées a décidé de ne pas reconnaitre votre handicap au taux requis pour l'attribution de l'AAH...'",
          "obligatoire": true
        }
      ]
    },
    {
      "id": "etape_rapo",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_rapo_envoye",
          "title": "Avez-vous envoyé un recours administratif préalable (RAPO) ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "oui", "label": "Oui", "subOptionsTitle": "Date d’envoi du RAPO", "subOptions": [
              { "value": "date_envoi", "type": "date", "label": "", "fieldId": "contentieux_rapo_date_envoi" }
            ]},
            { "value": "non", "label": "Non" },
            { "value": "ne_sais_pas", "label": "Je ne sais pas", "description": "Précisez si vous n'êtes pas sûr." }
          ]
        },
        {
          "id": "contentieux_rapo_reponse",
          "title": "La MDPH a-t-elle répondu à votre RAPO ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "contentieux_rapo_envoye === 'oui'",
          "options": [
            { "value": "oui", "label": "Oui", "subOptionsTitle": "Date de la réponse de la MDPH", "subOptions": [
              { "value": "date_reponse", "type": "date", "label": "", "fieldId": "contentieux_rapo_date_reponse" }
            ]},
            { "value": "non", "label": "Non" },
            { "value": "ne_sais_pas", "label": "Je ne sais pas" }
          ]
        },
        {
          "id": "contentieux_rapo_resultat",
          "title": "Quel a été le résultat du RAPO ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "condition_affichage": "contentieux_rapo_envoye === 'oui'",
          "options": [
            { "value": "refus_maintenu", "label": "refus maintenu" },
            { "value": "refus_partiellement_modifie", "label": "refus partiellement modifié" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        }
      ]
    },
    {
      "id": "etape4_situation_medicale",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_pathologie_principale",
          "title": "Quelle est votre pathologie principale ?",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : Je souffre d'une sclérose en plaques diagnostiquée en 2020, avec des poussées régulières affectant ma mobilité et ma fatigue chronique...",
          "obligatoire": true
        },
        {
          "id": "contentieux_duree_limitation_autonomie",
          "title": "Depuis combien de temps votre état limite votre autonomie ?",
          "description": "Indiquez la durée de vos limitations.",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "moins_6_mois", "label": "moins de 6 mois" },
            { "value": "6_mois_2_ans", "label": "entre 6 mois et 2 ans" },
            { "value": "plus_2_ans", "label": "plus de 2 ans" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        },
        {
          "id": "contentieux_suivi_medecin",
          "title": "Êtes-vous suivi par un médecin ou un spécialiste ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "oui", "label": "Oui", "hasTextField": true, "textFieldPlaceholder": "Précisez votre suivi médical" },
            { "value": "non", "label": "Non" },
            { "value": "autre", "label": "Autre" }
          ]
        },
        {
          "id": "contentieux_traitement_en_cours",
          "title": "Suivez-vous actuellement un traitement ou une prise en charge médicale ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "oui", "label": "Oui", "hasTextField": true, "textFieldPlaceholder": "Précisez" },
            { "value": "non", "label": "Non" },
            { "value": "autre", "label": "Autre" }
          ]
        }
      ]
    },
    {
      "id": "etape5_limitations_fonctionnelles",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_mobilite_limitee",
          "title": "Votre mobilité est-elle limitée ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "non", "label": "Non" },
            { "value": "legerement", "label": "légèrement" },
            { "value": "fortement", "label": "fortement" },
            { "value": "impossible_seul", "label": "impossible seul" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Expliquez" }
          ]
        },
        {
          "id": "contentieux_aide_quotidien",
          "title": "Avez-vous besoin d’aide dans votre vie quotidienne ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "non", "label": "Non" },
            { "value": "parfois", "label": "parfois" },
            { "value": "souvent", "label": "souvent", "subOptionsTitle": "Pour quelles tâches avez-vous besoin d’aide ?", "subOptions": [
              { "value": "courses", "label": "Faire les courses" },
              { "value": "repas", "label": "Préparer les repas" },
              { "value": "menage", "label": "Faire le ménage" },
              { "value": "deplacements", "label": "Se déplacer" },
              { "value": "administratif", "label": "Gérer les démarches administratives" },
              { "value": "autre", "label": "Autre" }
            ] },
            { "value": "toujours", "label": "toujours", "subOptionsTitle": "Pour quelles tâches avez-vous besoin d’aide ?", "subOptions": [
              { "value": "courses", "label": "Faire les courses" },
              { "value": "repas", "label": "Préparer les repas" },
              { "value": "menage", "label": "Faire le ménage" },
              { "value": "deplacements", "label": "Se déplacer" },
              { "value": "administratif", "label": "Gérer les démarches administratives" },
              { "value": "autre", "label": "Autre" }
            ] },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        },
        {
          "id": "contentieux_limitation_travail",
          "title": "Votre état de santé limite votre capacité à travailler ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "non", "label": "Non" },
            { "value": "partiellement", "label": "partiellement" },
            { "value": "fortement", "label": "fortement" },
            { "value": "impossible", "label": "impossible" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez" }
          ]
        }
      ]
    },
    {
      "id": "etape6_argumentaire",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_difficulte_quotidien",
          "title": "Décrivez votre plus grande difficulté au quotidien",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : Je ne peux plus me lever seul le matin. Ma femme doit m'aider pour m'habiller et préparer mes médicaments. Les douleurs m'empêchent de conduire...",
          "obligatoire": true
        },
        {
          "id": "contentieux_pourquoi_contestation",
          "title": "Expliquez pourquoi vous contestez la décision de la MDPH",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : La MDPH a estimé que mon taux d'incapacité était de 75%, mais mon médecin traitant et mon neurologue estiment que mes limitations sont bien plus sévères...",
          "obligatoire": true
        },
        {
          "id": "contentieux_elements_non_pris_en_compte",
          "title": "Quels éléments importants n'ont pas été pris en compte ?",
          "description": "",
          "type": "textarea",
          "placeholder": "Exemple : Mon hospitalisation de 3 semaines en 2023 n'a pas été mentionnée. Mon certificat médical mentionnant la progression de la maladie a été ignoré...",
          "obligatoire": true
        }
      ]
    },
    {
      "id": "etape7_demande_tribunal",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_demande_tribunal",
          "title": "Que demandez-vous au tribunal ?",
          "description": "",
          "type": "radio",
          "obligatoire": true,
          "options": [
            { "value": "annulation", "label": "annulation de la décision de la MDPH" },
            { "value": "reevaluation", "label": "réévaluation de votre situation" },
            { "value": "attribution", "label": "attribution de la prestation demandée" },
            { "value": "injonction", "label": "injonction à la MDPH de réexaminer votre dossier" },
            { "value": "autre", "label": "autre", "hasTextField": true, "textFieldPlaceholder": "Précisez votre demande" }
          ]
        }
      ]
    },
    {
      "id": "etape8_pieces_jointes",
      "title": "",
      "condition_section": "recours_type === 'contentieux'",
      "questions": [
        {
          "id": "contentieux_upload_notification",
          "title": "Notification de décision MDPH",
          "description": "",
          "type": "file",
          "obligatoire": false,
          "accept": ".pdf,.jpg,.jpeg,.png",
          "missingOptions": [
            { "value": "je_n_ai_pas_de_document", "label": "Je n'ai pas de document pour le moment" },
            { "value": "documents_perdus", "label": "Mes documents sont perdus", "hasTextField": true, "textFieldPlaceholder": "Expliquez la situation" }
          ]
        },
        {
          "id": "contentieux_upload_rapo",
          "title": "Copie du RAPO",
          "description": "",
          "type": "file",
          "obligatoire": false,
          "accept": ".pdf,.jpg,.jpeg,.png",
          "missingOptions": [
            { "value": "je_n_ai_pas_fait_de_rapo", "label": "Je n'ai pas fait de RAPO" },
            { "value": "rapo_perdu", "label": "Je ne trouve plus le RAPO", "hasTextField": true, "textFieldPlaceholder": "Expliquez la situation" }
          ]
        },
        {
          "id": "contentieux_upload_reponse_rapo",
          "title": "Réponse de la MDPH au RAPO",
          "description": "",
          "type": "file",
          "obligatoire": false,
          "accept": ".pdf,.jpg,.jpeg,.png",
          "missingOptions": [
            { "value": "pas_de_reponse", "label": "Pas de réponse de la MDPH" },
            { "value": "reponse_perdue", "label": "J'ai perdu la réponse", "hasTextField": true, "textFieldPlaceholder": "Expliquez la situation" }
          ]
        },
        {
          "id": "contentieux_upload_certificat",
          "title": "Certificat médical",
          "description": "",
          "type": "file",
          "obligatoire": false,
          "accept": ".pdf,.jpg,.jpeg,.png",
          "missingOptions": [
            { "value": "pas_de_certificat", "label": "Je n'ai pas de certificat" },
            { "value": "certificat_perdu", "label": "Je ne trouve plus le certificat", "hasTextField": true, "textFieldPlaceholder": "Expliquez la situation" }
          ]
        },
        {
          "id": "contentieux_upload_docs_medicaux",
          "title": "Autres documents médicaux",
          "description": "",
          "type": "file",
          "obligatoire": false,
          "multiple": true,
          "accept": ".pdf,.jpg,.jpeg,.png",
          "missingOptions": [
            { "value": "pas_d_autres_docs", "label": "Je n'ai pas d'autres documents" },
            { "value": "docs_medicaux_perdus", "label": "Mes documents sont perdus", "hasTextField": true, "textFieldPlaceholder": "Expliquez la situation" }
          ]
        }
      ]
    }
  ]
}
